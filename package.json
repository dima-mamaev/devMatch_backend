{
  "name": "devmatch-api",
  "version": "0.0.1",
  "description": "DevMatch API - Developer Hiring Platform",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "yarn build:api && yarn build:converter && yarn build:ai-agent",
    "build:api": "nest build api",
    "build:converter": "nest build video-converter",
    "build:ai-agent": "nest build ai-agent",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:converter": "nest start video-converter",
    "start:converter:dev": "nest start --watch video-converter",
    "start:converter:debug": "nest start --debug --watch video-converter",
    "start:converter:prod": "node dist/apps/video-converter/main.js",
    "start:ai-agent": "nest start ai-agent",
    "start:ai-agent:dev": "nest start --watch ai-agent",
    "start:ai-agent:debug": "nest start --debug --watch ai-agent",
    "start:ai-agent:prod": "node dist/apps/ai-agent/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "db:drop": "yarn typeorm schema:drop -d ./apps/api/src/ormconfig.ts",
    "db:reset": "yarn db:drop && yarn db:sync",
    "db:sync": "yarn typeorm schema:sync -d ./apps/api/src/ormconfig.ts",
    "db:log": "yarn typeorm schema:log -d ./apps/api/src/ormconfig.ts",
    "db:create": "yarn typeorm migration:create",
    "db:up": "yarn typeorm migration:run -d ./apps/api/src/ormconfig.ts",
    "db:down": "yarn typeorm migration:revert -d ./apps/api/src/ormconfig.ts",
    "db:check": "yarn typeorm migration:generate --check true -d ./apps/api/src/ormconfig.ts fake-filename",
    "db:generate": "yarn typeorm migration:generate -p true -d ./apps/api/src/ormconfig.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "docker:infra": "docker-compose up -d postgresdb17 redis",
    "docker:infra:down": "docker-compose down",
    "docker:app": "docker-compose --profile app up -d",
    "docker:app:build": "docker-compose --profile app build",
    "docker:logs": "docker-compose logs -f",
    "docker:build:api": "docker build --target api -t devmatch-api .",
    "docker:build:ai-agent": "docker build --target ai-agent -t devmatch-ai-agent .",
    "docker:build:converter": "docker build --target video-converter -t devmatch-converter ."
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.3",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.2.3",
    "@nestjs/microservices": "^11.1.6",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "auth0": "^4.28.0",
    "axios": "^1.11.0",
    "bullmq": "^5.66.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cloudinary": "^2.5.1",
    "express-oauth2-jwt-bearer": "^1.6.1",
    "graphql": "^16.12.0",
    "graphql-redis-subscriptions": "^2.7.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-type-json": "^0.3.2",
    "graphql-upload-ts": "^2.1.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "joi": "^18.0.0",
    "nestjs-cls": "^6.0.1",
    "node-mocks-http": "^1.17.2",
    "openai": "^6.27.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.25"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}