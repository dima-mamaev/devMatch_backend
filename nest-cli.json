{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/api/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/api",
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "video-converter": {
      "type": "application",
      "root": "apps/video-converter",
      "entryFile": "main",
      "sourceRoot": "apps/video-converter/src",
      "compilerOptions": {
        "tsConfigPath": "apps/video-converter/tsconfig.app.json"
      }
    },
    "ai-agent": {
      "type": "application",
      "root": "apps/ai-agent",
      "entryFile": "main",
      "sourceRoot": "apps/ai-agent/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ai-agent/tsconfig.app.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    }
  }
}
