# Server
PORT=4000
TZ=UTC
ENVIRONMENT=development

# Database (PostgreSQL)
# Use 'postgres' as host when running in Docker, 'localhost' for local dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=devmatch
POSTGRES_PASSWORD=devmatch
POSTGRES_DB=devmatch

# Authentication (Auth0)
AUTH0_AUDIENCE=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis (required for BullMQ job queues)
# Use 'redis' as host when running in Docker, 'localhost' for local dev
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI (AI Match feature)
OPENAI_API_KEY=
OPENAI_ASSISTANT_ID=

# AI Agent Service
AI_AGENT_URL=http://localhost:4001
AI_AGENT_PORT=4001
